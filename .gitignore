# Gradle
.gradle/
# Build output is redirected outside the project (see build.gradle:
# %USERPROFILE%\.snackpgx-build), but ignore a local build/ just in case.
build/

# Distributables (large, regenerated by gradlew jpackage / packaging)
dist/

# Eclipse / IDE
.settings/
bin/
.project
.classpath

# Excel temporary / lock files
~$*

# Clinical (patient) annotation files must never be committed. Only the public
# DRY WGS and RM reference samples are tracked under "input files/".
input files/Clinical/
